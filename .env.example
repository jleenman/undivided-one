# Run `./setup` to create `.env` and generate the secrets below automatically.

# Local PostgreSQL connection string for host-based development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/undivided_one

# Docker Compose overrides DATABASE_URL automatically for the app container.
# The Docker dev server is exposed on port 3001 by default.
APP_PORT=3001

# Used to encrypt JWT tokens
PAYLOAD_SECRET=CHANGE_ME

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Secret used to authenticate cron jobs
CRON_SECRET=CHANGE_ME

# Used to validate preview requests
PREVIEW_SECRET=CHANGE_ME
